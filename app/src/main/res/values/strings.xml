    <!-- Tutorial — step descriptions -->
    <string name="tutorial_desc_1">This is the Care tab. Hold your phone to a clothing tag to read its care instructions. You can also tap the Scan Care Label button to read a label with the camera. Tap Got it to continue.</string>
    <string name="tutorial_desc_2">After scanning a tag the Add to Wardrobe button appears at the bottom. Find it and tap it.</string>
    <string name="tutorial_desc_3">This is the Write tab. Choose answers about a clothing item then hold your phone to a blank NFC tag to save it. You can also tap the camera button to pre-fill fields automatically. Tap Got it to continue.</string>
    <string name="tutorial_desc_4">Find the Next button and tap it to confirm your answer and move to the next question.</string>
    <string name="tutorial_desc_5">Find the Skip button and tap it to leave a question blank and move on.</string>
    <string name="tutorial_desc_6">Find the Back button and tap it to return to the previous question.</string>
    <string name="tutorial_desc_7">Find the camera button and tap it to scan your clothing item and pre-fill fields automatically.</string>
    <string name="tutorial_desc_8">Tip: scan an existing LexaWEAR tag on this screen to load and edit it. Tap Got it to continue.</string>
    <string name="tutorial_desc_9">This is your Wardrobe. Tagged clothing items appear here. Find the Scan Tag button at the bottom and tap it.</string>
    <string name="tutorial_desc_10">Find the Filters button and tap it to open the filter screen.</string>
    <string name="tutorial_desc_11">Find the voice filter microphone and tap it to filter your wardrobe by speaking.</string>
    <string name="tutorial_desc_12">This is the Filter screen. Arrow buttons cycle through options. Find any Next arrow and tap it.</string>
    <string name="tutorial_desc_13">Find the Apply button and tap it to apply your filters.</string>
    <string name="tutorial_desc_14">Find the Clear button and tap it to reset all filters.</string>
    <string name="tutorial_desc_15">You have completed the tutorial. Tap Got it to start using LexaWEAR.</string>

