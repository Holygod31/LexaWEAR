<?xml version="1.0" encoding="utf-8"?>

<!--
    input_background.xml — Rounded rectangle background for text input fields.

    Used by:
      - et_step_input (fragment_nfc.xml)         ← wizard free-text entry
      - et_custom_size (fragment_nfc.xml)         ← custom size entry
      - tv_type/color/season/formality_value      ← FilterFragment carousel value labels
        (fragment_filter.xml)

    Surface colour fill + 1dp border + 8dp corner radius gives a card-style
    input appearance that works in both light and dark themes via theme attributes.
-->

<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Theme-aware surface fill — adapts to light/dark mode automatically -->
    <solid android:color="?attr/colorSurface" />

    <corners android:radius="8dp" />

    <!-- Subtle border using colorControlNormal — visible in both themes -->
    <stroke android:width="1dp" android:color="?attr/colorControlNormal" />

</shape>