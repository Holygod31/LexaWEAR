<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Care Instructions"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="12dp" />

            <!-- Status -->
            <TextView
                android:id="@+id/tv_care_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scan a tag to see care instructions."
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface"
                android:gravity="center"
                android:padding="10dp"
                android:background="@drawable/status_background"
                android:layout_marginBottom="24dp"
                android:accessibilityLiveRegion="polite" />

            <!-- Care info cards -->
            <LinearLayout
                android:id="@+id/layout_care_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- Scan button pinned to bottom -->
    <Button
        android:id="@+id/btn_care_scan"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:text="Scan Tag"
        android:textSize="18sp"
        android:layout_margin="16dp"
        android:contentDescription="Scan NFC tag to read care instructions" />

    <!-- Add to wardrobe button (hidden until tag is scanned) -->
    <Button
        android:id="@+id/btn_add_to_wardrobe"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Add to Wardrobe"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        android:contentDescription="Add this clothing item to your wardrobe" />

</LinearLayout>