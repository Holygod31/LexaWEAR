<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Care Instructions"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="12dp" />

            <!-- Status -->
            <TextView
                android:id="@+id/tv_care_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hold your phone to a clothing tag."
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface"
                android:gravity="center"
                android:padding="10dp"
                android:background="@drawable/status_background"
                android:layout_marginBottom="16dp"
                android:accessibilityLiveRegion="polite" />

            <!-- Legacy tag warning banner -->
            <TextView
                android:id="@+id/tv_legacy_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#D32F2F"
                android:padding="12dp"
                android:background="@drawable/status_background"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:accessibilityLiveRegion="polite" />

            <!-- Care info cards -->
            <LinearLayout
                android:id="@+id/layout_care_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- Add to wardrobe button pinned to bottom, hidden until tag scanned -->
    <Button
        android:id="@+id/btn_add_to_wardrobe"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:text="Add to Wardrobe"
        android:textSize="18sp"
        android:layout_margin="16dp"
        android:visibility="gone"
        android:contentDescription="Add this clothing item to your wardrobe" />

</LinearLayout>