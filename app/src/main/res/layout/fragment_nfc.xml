<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Write Tag"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="8dp" />

        <!-- Status -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fill in the details and tap Write to Tag."
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/status_background"
            android:layout_marginBottom="12dp"
            android:accessibilityLiveRegion="polite" />

        <!-- Name row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.35"
                android:text="Name"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground" />

            <EditText
                android:id="@+id/et_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.65"
                android:hint="e.g. Blue Jacket"
                android:textSize="14sp"
                android:padding="8dp"
                android:inputType="textCapSentences"
                android:background="@drawable/input_background"
                android:contentDescription="Item name input" />

        </LinearLayout>

        <!-- Material row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.35"
                android:text="Material"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground" />

            <Spinner
                android:id="@+id/spinner_material"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.65"
                android:background="@drawable/input_background"
                android:padding="8dp"
                android:contentDescription="Select material" />

        </LinearLayout>

        <!-- Wash row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.35"
                android:text="Wash"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground" />

            <Spinner
                android:id="@+id/spinner_wash"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.65"
                android:background="@drawable/input_background"
                android:padding="8dp"
                android:contentDescription="Select wash temperature" />

        </LinearLayout>

        <!-- Drying row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.35"
                android:text="Drying"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground" />

            <Spinner
                android:id="@+id/spinner_dry"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.65"
                android:background="@drawable/input_background"
                android:padding="8dp"
                android:contentDescription="Select drying method" />

        </LinearLayout>

        <!-- Ironing row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.35"
                android:text="Ironing"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground" />

            <Spinner
                android:id="@+id/spinner_iron"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.65"
                android:background="@drawable/input_background"
                android:padding="8dp"
                android:contentDescription="Select ironing temperature" />

        </LinearLayout>

        <!-- Bleaching row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.35"
                android:text="Bleaching"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground" />

            <Spinner
                android:id="@+id/spinner_bleach"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.65"
                android:background="@drawable/input_background"
                android:padding="8dp"
                android:contentDescription="Select bleaching option" />

        </LinearLayout>

        <!-- Dry Clean row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.35"
                android:text="Dry Clean"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground" />

            <Spinner
                android:id="@+id/spinner_dryclean"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.65"
                android:background="@drawable/input_background"
                android:padding="8dp"
                android:contentDescription="Select dry cleaning option" />

        </LinearLayout>

        <!-- Notes row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.5"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.35"
                android:text="Notes"
                android:textSize="14sp"
                android:textColor="?attr/colorOnBackground" />

            <EditText
                android:id="@+id/et_notes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.65"
                android:hint="Extra notes..."
                android:textSize="14sp"
                android:padding="8dp"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="2"
                android:gravity="top"
                android:background="@drawable/input_background"
                android:contentDescription="Extra notes input" />

        </LinearLayout>

    </LinearLayout>

    <!-- Write button pinned to bottom -->
    <Button
        android:id="@+id/btn_write"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:text="Write to Tag"
        android:textSize="18sp"
        android:layout_margin="16dp"
        android:contentDescription="Write entered information to NFC tag" />

</LinearLayout>