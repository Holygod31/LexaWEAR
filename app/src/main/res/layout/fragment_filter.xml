<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filters"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnBackground"
        android:layout_margin="16dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Type carousel -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btn_type_prev"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="◀"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="Previous type" />

                <TextView
                    android:id="@+id/tv_type_value"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnBackground"
                    android:background="@drawable/input_background"
                    android:accessibilityLiveRegion="polite" />

                <Button
                    android:id="@+id/btn_type_next"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="▶"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="Next type" />

            </LinearLayout>

            <!-- Color carousel -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Color"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btn_color_prev"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="◀"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="Previous color" />

                <TextView
                    android:id="@+id/tv_color_value"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnBackground"
                    android:background="@drawable/input_background"
                    android:accessibilityLiveRegion="polite" />

                <Button
                    android:id="@+id/btn_color_next"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="▶"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="Next color" />

            </LinearLayout>

            <!-- Season carousel -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Season"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btn_season_prev"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="◀"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="Previous season" />

                <TextView
                    android:id="@+id/tv_season_value"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnBackground"
                    android:background="@drawable/input_background"
                    android:accessibilityLiveRegion="polite" />

                <Button
                    android:id="@+id/btn_season_next"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="▶"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="Next season" />

            </LinearLayout>

            <!-- Formality carousel -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Formality"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btn_formality_prev"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="◀"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="Previous formality" />

                <TextView
                    android:id="@+id/tv_formality_value"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnBackground"
                    android:background="@drawable/input_background"
                    android:accessibilityLiveRegion="polite" />

                <Button
                    android:id="@+id/btn_formality_next"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="▶"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="Next formality" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Apply / Clear buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_filter_clear"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Clear"
            android:textSize="18sp"
            android:contentDescription="Clear all filters" />

        <Button
            android:id="@+id/btn_filter_apply"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:text="Apply"
            android:textSize="18sp"
            android:contentDescription="Apply filters and return to wardrobe" />

    </LinearLayout>

</LinearLayout>