<?xml version="1.0" encoding="utf-8"?>

<!--
    fragment_filter.xml — Filter tab layout (FilterFragment).

    Structure:
      LinearLayout (vertical, full height)
        ├─ TextView (title)                     ← static heading
        ├─ ScrollView (weight=1)                ← scrollable carousel area
        │    └─ LinearLayout (vertical, padding=16dp)
        │         ├─ [label + carousel] × 4    ← Type / Colour / Season / Formality
        │         │   Each carousel row:
        │         │     Button (◀ prev, 72dp) | TextView (value, weight=1) | Button (▶ next, 72dp)
        └─ LinearLayout (action row)            ← Clear and Apply buttons, pinned at bottom

    Each carousel value TextView uses accessibilityLiveRegion="polite" so TalkBack
    announces the new option name each time the user taps prev/next, without
    requiring the user to navigate focus back to the display label.

    Apply and Clear are outside the ScrollView so they stay pinned at the bottom
    regardless of how many carousels are visible above.

    Carousel button IDs follow the pattern btn_{axis}_{prev|next} — these IDs
    are referenced directly in TutorialManager.allButtonIds (steps 12–14).
-->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Static screen title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filter_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnBackground"
        android:layout_margin="16dp" />

    <!-- Scrollable carousel area — weight=1 fills space above the action row -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Type carousel ──────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_type_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="8dp" />

            <!--
                Carousel row: ◀ (72dp fixed) | value label (weight=1) | ▶ (72dp fixed).
                72dp buttons meet minimum accessible touch target size.
                tv_type_value is updated by FilterFragment.setupCarousel() on each tap.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btn_type_prev"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="◀"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="@string/btn_prev_type" />

                <!--
                    Current type value — accessibilityLiveRegion="polite" announces
                    each new option to TalkBack when prev/next is tapped.
                -->
                <TextView
                    android:id="@+id/tv_type_value"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnBackground"
                    android:background="@drawable/input_background"
                    android:accessibilityLiveRegion="polite" />

                <Button
                    android:id="@+id/btn_type_next"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="▶"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="@string/btn_next_type" />

            </LinearLayout>

            <!-- ── Colour carousel ────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_color_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="8dp" />

            <!-- Carousel row — same structure as Type; see Type carousel comment above -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btn_color_prev"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="◀"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="@string/btn_prev_color" />

                <TextView
                    android:id="@+id/tv_color_value"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnBackground"
                    android:background="@drawable/input_background"
                    android:accessibilityLiveRegion="polite" />

                <Button
                    android:id="@+id/btn_color_next"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="▶"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="@string/btn_next_color" />

            </LinearLayout>

            <!-- ── Season carousel ────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_season_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="8dp" />

            <!-- Carousel row — same structure as Type; see Type carousel comment above -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btn_season_prev"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="◀"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="@string/btn_prev_season" />

                <TextView
                    android:id="@+id/tv_season_value"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnBackground"
                    android:background="@drawable/input_background"
                    android:accessibilityLiveRegion="polite" />

                <Button
                    android:id="@+id/btn_season_next"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="▶"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="@string/btn_next_season" />

            </LinearLayout>

            <!-- ── Formality carousel ─────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_formality_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnBackground"
                android:layout_marginBottom="8dp" />

            <!-- Carousel row — same structure as Type; see Type carousel comment above -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btn_formality_prev"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="◀"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="@string/btn_prev_formality" />

                <TextView
                    android:id="@+id/tv_formality_value"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnBackground"
                    android:background="@drawable/input_background"
                    android:accessibilityLiveRegion="polite" />

                <Button
                    android:id="@+id/btn_formality_next"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="▶"
                    android:textSize="22sp"
                    android:padding="0dp"
                    android:contentDescription="@string/btn_next_formality" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!--
        Action row — pinned at bottom, outside ScrollView.
        Clear resets all four axes to index 0 ("no filter").
        Apply passes current codes to MainActivity.applyFiltersFromFilter().
        Both buttons share the row width equally (weight=1 each).
        Height 72dp matches minimum accessible touch target size.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_filter_clear"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/btn_filter_clear"
            android:textSize="18sp"
            android:contentDescription="@string/btn_filter_clear_description" />

        <Button
            android:id="@+id/btn_filter_apply"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:text="@string/btn_filter_apply"
            android:textSize="18sp"
            android:contentDescription="@string/btn_filter_apply_description" />

    </LinearLayout>

</LinearLayout>