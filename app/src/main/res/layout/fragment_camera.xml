<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Live camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Live result overlay -->
    <TextView
        android:id="@+id/tv_camera_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#AA000000"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:padding="16dp"
        android:text="@string/camera_overlay_clothing"
        android:accessibilityLiveRegion="polite"
        android:contentDescription="@string/camera_overlay_live_description" />

    <!-- Mode indicator -->
    <TextView
        android:id="@+id/tv_camera_mode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="#AA1565C0"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:padding="8dp"
        android:text="@string/camera_mode_clothing"
        android:contentDescription="@string/camera_mode_current_description" />

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#AA000000"
        android:padding="16dp">

        <!-- Status message -->
        <TextView
            android:id="@+id/tv_camera_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:text="@string/camera_analyzing"
            android:accessibilityLiveRegion="polite" />

        <!-- Cancel / Capture / Care label row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_camera_cancel"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/camera_btn_cancel"
                android:textSize="15sp"
                android:contentDescription="@string/camera_btn_cancel_description" />

            <Button
                android:id="@+id/btn_camera_capture"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="2"
                android:text="@string/camera_btn_capture"
                android:textSize="17sp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/camera_btn_capture_description" />

            <Button
                android:id="@+id/btn_camera_care"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:text="@string/camera_btn_care_label"
                android:textSize="13sp"
                android:contentDescription="@string/camera_btn_care_label_description" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>